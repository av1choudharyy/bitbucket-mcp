# Required: HTTP Access Token from Bitbucket Cloud
# Create at: https://bitbucket.org/<workspace>/workspace/settings/access-tokens
BITBUCKET_TOKEN=your_http_access_token

# Required: Bitbucket workspace slug
BITBUCKET_WORKSPACE=your_workspace_slug

# Optional: override API base URL (default: https://api.bitbucket.org/2.0)
# BITBUCKET_API_URL=https://api.bitbucket.org/2.0
